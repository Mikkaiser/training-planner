NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth (Google): enable under Supabase → Authentication → Providers.
# Under Authentication → URL Configuration, add redirect URLs:
#   http://localhost:3000/auth/callback
#   https://<your-production-domain>/auth/callback

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Supabase Project Settings → Database)
DATABASE_URL=

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://your-domain.com
