## TypeScript Conventions

- **Always** define types for Supabase table rows in `lib/types.ts` — never use `any`
- Use `type` for data shapes, `interface` for component props
- Derive types from the Supabase schema where possible (use generated types from `supabase gen types`)
- Never cast with `as` unless unavoidable — prefer type guards

```ts
// lib/types.ts

export type Plan = {
  id: string
  title: string
  student_name: string
  created_at: string
}

export type Phase = {
  id: string
  plan_id: string
  title: string
  order_index: number
}

export type Block = {
  id: string
  phase_id: string
  title: string
  verb_level: 'Recognize' | 'Apply' | 'Produce' | 'Optimize'
  competence_type: 'Development' | 'Testing' | 'Analysis' | 'Transversal'
  hours: number
  order_index: number
}

export type Gate = {
  id: string
  plan_id: string
  after_block_id: string
  status: 'pending' | 'passed' | 'failed'
  hours_threshold: number
}
```

Component props:
```ts
// ✅ Use interface for props
interface PlanCardProps {
  plan: Plan
  onClick: (id: string) => void
}
```

